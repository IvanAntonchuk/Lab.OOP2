@startuml
left to right direction
skinparam node {
  BackgroundColor LightCyan
  BorderColor DarkBlue
}
skinparam artifact {
  BackgroundColor White
}

node "Комп'ютер користувача" as UserPC {
  node "Операційна система" as OS {
    artifact "LinkManager.exe\n(Виконуваний файл програми)" as App
    
    folder "Робоча директорія" {
      artifact "links.json\n(База збережених посилань)" as Data
      artifact "Qt5Core / Qt5Widgets\n(Динамічні бібліотеки)" as Dlls
    }
  }
}

node "Зовнішній Web-сервер" as Web {
  artifact "HTML сторінка\n(Джерело тегу <title>)" as WebPage
}

App ..> Dlls : <<uses>>
App --> Data : <<read / write>>
App --> WebPage : HTTP GET запит (httplib)

@enduml
